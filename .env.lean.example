# ===========================================
# AUTONOMOUS LIVING - LEAN ENVIRONMENT TEMPLATE
# ===========================================
# Simplified version for public deployment
# Copy this file to .env and update values

# --- PROJECT CONFIGURATION ---
COMPOSE_PROJECT_NAME=autonomous-lean
TZ=Europe/Warsaw

# --- POSTGRESQL (Central Database) ---
DB_USER=autonomous
DB_PASSWORD=changeme
DB_HOST=postgres
DB_PORT=5432

# --- N8N AUTOMATION ---
N8N_PORT=5678
N8N_ENCRYPTION_KEY=changeme
N8N_WEBHOOK_URL=http://localhost:5678

# --- DIGITAL TWIN API ---
DIGITAL_TWIN_PORT=5677

# --- LOCAL AI / LLM ---
OLLAMA_PORT=11434
QDRANT_PORT=6333
GEMINI_API_KEY=your_gemini_api_key_here

# --- MONITORING ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003
GRAFANA_PASSWORD=changeme

# --- TELEGRAM BOT ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- GOOGLE SHEETS (Sources of Truth) ---
GOOGLE_SHEET_ID_FINANCE=your_sheet_id
GOOGLE_SHEET_ID_TRAINING=your_sheet_id
GOOGLE_SHEET_ID_PANTRY=your_sheet_id
GOOGLE_SHEET_ID_LOGISTICS=your_sheet_id
