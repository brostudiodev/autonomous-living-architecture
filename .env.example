# ===========================================
# AUTONOMOUS LIVING - ENVIRONMENT TEMPLATE
# ===========================================
# Copy this file to .env and update values for your deployment
# cp .env.example .env

# ===========================================
# PROJECT CONFIGURATION
# ===========================================
COMPOSE_PROJECT_NAME=autonomous
TZ=Europe/Warsaw
PUID=1000
PGID=1000

# ===========================================
# POSTGRESQL (Central Database)
# ===========================================
# Used by: postgres service, n8n, Digital Twin API
POSTGRES_USER=autonomous
POSTGRES_PASSWORD=changeme
POSTGRES_DB=autonomous
POSTGRES_PORT=5432

# Legacy/Script compatibility (should match above)
DB_USER=autonomous
DB_PASSWORD=changeme
DB_HOST=postgres
DB_PORT=5432

# ===========================================
# N8N AUTOMATION
# ===========================================
N8N_PORT=5678
N8N_ENCRYPTION_KEY=changeme
N8N_USER_MANAGEMENT_JWT_SECRET=changeme
N8N_WEBHOOK_URL=http://localhost:5678

# ===========================================
# DIGITAL TWIN API
# ===========================================
DIGITAL_TWIN_PORT=5677

# ===========================================
# LOCAL AI / LLM (Ollama, Qdrant, WebUI)
# ===========================================
OLLAMA_PORT=11434
QDRANT_PORT=6333
QDRANT_GRPC=6334
OPEN_WEBUI_PORT=3000
WEBUI_SECRET_KEY=change-me-in-production

# ===========================================
# MONITORING (Prometheus, Grafana)
# ===========================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme
METRICS_PORT=8081
NODE_EXPORTER_PORT=9100

# ===========================================
# PRODUCTIVITY (ActivityWatch)
# ===========================================
ACTIVITYWATCH_PORT=5600

# ===========================================
# TELEGRAM BOT (G04/G11 Notifiers)
# ===========================================
TELEGRAM_BOT_TOKEN=changeme
TELEGRAM_CHAT_ID=changeme
TELEGRAM_USER_ID=changeme

# ===========================================
# EXTERNAL APIs (Health, Finance, AI)
# ===========================================
GEMINI_API_KEY=changeme
GOOGLE_SHEETS_ID=changeme

# Withings
WITHINGS_CLIENT_ID=changeme
WITHINGS_CLIENT_SECRET=changeme

# Zepp / Amazfit
ZEPP_EMAIL=changeme
ZEPP_PASSWORD=changeme
ZEPP_TOKEN=changeme
ZEPP_REFRESH_TOKEN=changeme

# Home Assistant (S08)
HA_INTERNAL_IP=192.168.x.x
HASS_URL=http://192.168.x.x:8123
HA_TOKEN=changeme

# MariaDB (Optional legacy)
MARIADB_HOST=192.168.x.x
MARIADB_USER=changeme
MARIADB_PASSWORD=changeme
MARIADB_DATABASE=homeassistant

# ===========================================
# OBSIDIAN WEB (Optional profile)
# ===========================================
OBSIDIAN_HTTP_PORT=3010
OBSIDIAN_HTTPS_PORT=3011
OBSIDIAN_CONFIG_PATH=./obsidian/config
OBSIDIAN_DATA_PATH=./obsidian/data

# Google Sheets IDs
GOOGLE_SHEET_ID_LOGISTICS=changeme
GOOGLE_SHEET_ID_RELATIONSHIPS=changeme
GOOGLE_SHEET_ID_FINANCE=changeme
GOOGLE_SHEET_ID_TRAINING=changeme
GOOGLE_SHEET_ID_PANTRY=changeme
